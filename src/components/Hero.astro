---
import HeroContent from "./HeroContent.tsx";
import type { Locale } from "../i18n/translations";

interface Props {
    lang?: Locale;
}

const { lang = "en" } = Astro.props;
---

<section class="hero">
    <div class="section-inner hero-content">
        {/* Split grid Hero layout */}
        <HeroContent client:load lang={lang} />
    </div>
</section>

<style>
    .hero {
        position: relative;
        overflow: hidden;
        padding-top: 72px;
        padding-bottom: 0;
        padding-inline: 24px;
        background: var(--color-canvas);
        border-bottom: 1px solid var(--color-hairline);
    }

    .hero-content {
        position: relative;
        z-index: 10;
    }
</style>
