---
import HeroContent from './HeroContent.tsx';
---

<section class="hero">
  <!-- Ambient texture — very subtle, not glowing -->
  <div class="hero-bg" aria-hidden="true"></div>

  <!-- App preview — faded right side -->
  <div class="hero-preview" aria-hidden="true">
    <div class="hero-preview-fade"></div>
    <div class="hero-preview-fade-bottom"></div>
    <div class="hero-preview-img-wrap">
      <img
        src="/preview.png"
        alt=""
        class="hero-preview-img"
        loading="eager"
      />
    </div>
  </div>

  <div class="section-inner hero-content">
    <!-- Animated text block — staggered entrance on load -->
    <HeroContent client:load />
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-top: 96px;
    padding-bottom: 112px;
    padding-inline: 24px;
    background: var(--color-canvas);
  }

  /* Subtle noise/grain feel — not a glowing orb */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(ellipse 55% 45% at 18% 65%, rgba(91, 191, 181, 0.04) 0%, transparent 65%),
      radial-gradient(ellipse 35% 30% at 75% 25%, rgba(143, 155, 186, 0.03) 0%, transparent 60%);
    pointer-events: none;
  }

  /* Preview image fades */
  .hero-preview {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hero-preview-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, #141312 28%, rgba(20, 19, 18, 0.7) 58%, rgba(20, 19, 18, 0.2) 100%);
    z-index: 1;
  }

  .hero-preview-fade-bottom {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, #141312 0%, transparent 35%);
    z-index: 1;
  }

  .hero-preview-img-wrap {
    position: absolute;
    right: -8%;
    top: 12%;
    width: 72rem;
    max-width: none;
    opacity: 0.45;
  }

  .hero-preview-img {
    width: 100%;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.04);
    box-shadow: 0 48px 120px rgba(0, 0, 0, 0.55);
  }

  /* Content */
  .hero-content {
    position: relative;
    z-index: 10;
  }

  .hero-text {
    max-width: 580px;
  }

  /* Eyebrow */
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 24px;
  }

  .eyebrow-dot {
    width: 5px;
    height: 5px;
    border-radius: 9999px;
    background: var(--color-accent);
    flex-shrink: 0;
    opacity: 0.8;
  }

  /* Headline */
  .hero-headline {
    font-size: clamp(2.5rem, 6vw, 4.25rem);
    font-weight: 400;
    line-height: 1.06;
    letter-spacing: -0.04em;
    color: var(--color-ink);
    margin-bottom: 24px;
  }

  .hero-accent {
    font-style: italic;
    font-family: var(--font-serif);
    color: var(--color-accent-light);
    letter-spacing: -0.02em;
  }

  /* Description */
  .hero-desc {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-body);
    max-width: 48ch;
    margin-bottom: 36px;
  }

  /* Actions */
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
  }
</style>
