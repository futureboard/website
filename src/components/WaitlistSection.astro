---
import WaitlistForm from './WaitlistForm.tsx';
---

<section id="waitlist" class="bg-canvas border-t border-hairline py-24 px-6 relative overflow-hidden">
  <!-- Ambient glow behind section -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(ellipse 50% 60% at 80% 50%, rgba(88,203,203,0.04) 0%, transparent 70%);"
  ></div>

  <div class="max-w-[1200px] mx-auto relative">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Copy -->
      <div>
        <p class="text-accent text-xs font-mono tracking-widest uppercase mb-4">Early Access</p>
        <h2
          class="text-ink font-normal mb-4"
          style="font-size: 32px; line-height: 40px; letter-spacing: -0.8px;"
        >
          Be first to try<br />
          <span class="font-serif italic" style="color:#73C7C7;">Futureboard.</span>
        </h2>
        <p class="text-body text-base leading-6 max-w-sm mb-8">
          Futureboard is in active development. Join the waitlist to get early access, shape the roadmap, and follow the build.
        </p>
        <ul class="flex flex-col gap-3">
          <li class="flex items-start gap-3 text-body text-sm leading-5">
            <span
              class="w-1.5 h-1.5 mt-2 rounded-full flex-shrink-0"
              style="background:#58CBCB; box-shadow: 0 0 5px #58CBCB;"
            ></span>
            Early access to native builds when ready
          </li>
          <li class="flex items-start gap-3 text-body text-sm leading-5">
            <span
              class="w-1.5 h-1.5 mt-2 rounded-full flex-shrink-0"
              style="background:#58CBCB; box-shadow: 0 0 5px #58CBCB;"
            ></span>
            Input on features and roadmap priorities
          </li>
          <li class="flex items-start gap-3 text-body text-sm leading-5">
            <span
              class="w-1.5 h-1.5 mt-2 rounded-full flex-shrink-0"
              style="background:#58CBCB; box-shadow: 0 0 5px #58CBCB;"
            ></span>
            No spam — updates only when something ships
          </li>
        </ul>
      </div>

      <!-- Form card -->
      <div
        class="bg-canvas-soft rounded-md p-6 lg:p-8"
        style="border: 1px solid #2E3747; box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);"
      >
        <WaitlistForm client:load />
      </div>

    </div>
  </div>
</section>
