---
import WaitlistForm from './WaitlistForm.tsx';
import FadeUp from './motion/FadeUp.tsx';
---

<section id="waitlist" class="waitlist-section">
  <!-- Subtle ambient, not a glowing blob -->
  <div class="waitlist-bg" aria-hidden="true"></div>

  <div class="section-inner waitlist-inner">

    <!-- Copy -->
    <FadeUp client:visible>
      <div class="waitlist-copy">
        <span class="eyebrow">Early Access</span>
        <h2 class="waitlist-headline">
          Be first to try<br />
          <em class="waitlist-accent">Futureboard.</em>
        </h2>
        <p class="waitlist-desc">
          Futureboard is in active development. Join the waitlist to get early access, shape the roadmap, and follow the build.
        </p>

        <ul class="waitlist-perks">
          <li>
            <span class="perk-dot" aria-hidden="true"></span>
            Early access to native builds when ready
          </li>
          <li>
            <span class="perk-dot" aria-hidden="true"></span>
            Input on features and roadmap priorities
          </li>
          <li>
            <span class="perk-dot" aria-hidden="true"></span>
            No spam — updates only when something ships
          </li>
        </ul>
      </div>
    </FadeUp>

    <!-- Form card -->
    <FadeUp client:visible delay={0.12}>
      <div class="waitlist-card">
        <WaitlistForm client:load />
      </div>
    </FadeUp>

  </div>
</section>

<style>
  .waitlist-section {
    background: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
    padding-block: 88px;
    padding-inline: 24px;
    position: relative;
    overflow: hidden;
  }

  .waitlist-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 45% 55% at 80% 50%, rgba(91, 191, 181, 0.03) 0%, transparent 65%);
    pointer-events: none;
  }

  .waitlist-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 56px;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .waitlist-inner {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Copy */
  .waitlist-headline {
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    font-weight: 400;
    letter-spacing: -0.04em;
    color: var(--color-ink);
    line-height: 1.1;
    margin-top: 12px;
    margin-bottom: 16px;
  }

  .waitlist-accent {
    font-style: italic;
    font-family: var(--font-serif);
    color: var(--color-accent-light);
  }

  .waitlist-desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-body);
    max-width: 38ch;
    margin-bottom: 28px;
  }

  /* Perks */
  .waitlist-perks {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .waitlist-perks li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--color-body);
  }

  .perk-dot {
    width: 5px;
    height: 5px;
    border-radius: 9999px;
    background: var(--color-accent);
    flex-shrink: 0;
    margin-top: 7px;
    opacity: 0.7;
  }

  /* Form card */
  .waitlist-card {
    background: var(--color-canvas-soft);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    padding: 28px;
  }
</style>
