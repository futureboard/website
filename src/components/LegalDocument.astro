---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  EnglishContent: any;
  ThaiContent: any;
}

const { eyebrow, title, description, EnglishContent, ThaiContent } = Astro.props;
const groupId = title.toLowerCase().replace(/[^a-z0-9]+/g, '-');
---

<section class="legal-hero">
  <div class="section-inner">
    <span class="eyebrow">{eyebrow}</span>
    <h1 class="legal-title">{title}</h1>
    <p class="legal-desc">{description}</p>
  </div>
</section>

<main class="legal-body">
  <div class="section-inner">

    <!-- Language tabs -->
    <div
      class="lang-tabs"
      role="tablist"
      aria-label="Document language"
      data-language-tabs={groupId}
    >
      <button
        type="button"
        class="legal-tab active"
        role="tab"
        aria-selected="true"
        aria-controls={`${groupId}-en`}
        data-language-tab="en"
      >
        English
      </button>
      <button
        type="button"
        class="legal-tab"
        role="tab"
        aria-selected="false"
        aria-controls={`${groupId}-th`}
        data-language-tab="th"
      >
        ภาษาไทย
      </button>
    </div>

    <!-- Content panels -->
    <article
      id={`${groupId}-en`}
      class="legal-markdown"
      role="tabpanel"
      data-language-panel="en"
    >
      <EnglishContent />
    </article>

    <article
      id={`${groupId}-th`}
      class="legal-markdown"
      role="tabpanel"
      lang="th"
      hidden
      data-language-panel="th"
    >
      <ThaiContent />
    </article>

  </div>
</main>

<style>
  /* Hero */
  .legal-hero {
    border-bottom: 1px solid var(--color-hairline);
    background: var(--color-canvas);
    padding-block: 56px 48px;
    padding-inline: 24px;
  }

  .legal-title {
    margin-top: 14px;
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 500;
    color: var(--color-ink);
    letter-spacing: -0.04em;
    max-width: 640px;
  }

  .legal-desc {
    margin-top: 14px;
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-body);
    max-width: 520px;
  }

  /* Body */
  .legal-body {
    padding-block: 40px 80px;
    padding-inline: 24px;
    background: var(--color-canvas);
  }

  /* Language tabs */
  .lang-tabs {
    display: inline-flex;
    gap: 2px;
    background: var(--color-canvas-soft);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
    padding: 4px;
    margin-bottom: 36px;
  }
</style>

<script>
  document.querySelectorAll('[data-language-tabs]').forEach((tabGroup) => {
    const wrapper = tabGroup.parentElement;
    if (!wrapper) return;

    const tabs   = Array.from(tabGroup.querySelectorAll('[data-language-tab]'));
    const panels = Array.from(wrapper.querySelectorAll('[data-language-panel]'));

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const language = tab.getAttribute('data-language-tab');

        tabs.forEach((btn) => {
          const isActive = btn === tab;
          btn.setAttribute('aria-selected', String(isActive));
          btn.classList.toggle('active', isActive);
        });

        panels.forEach((panel) => {
          panel.toggleAttribute('hidden', panel.getAttribute('data-language-panel') !== language);
        });
      });
    });
  });
</script>
