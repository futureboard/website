---
import FadeUp from "./motion/FadeUp.tsx";
import { translations, type Locale } from "../i18n/translations";

interface Props {
    lang?: Locale;
}

const { lang = "en" } = Astro.props;
const t = translations[lang];

const products = [
    {
        index: "01",
        tag: t.product_express_tag,
        name: t.product_express_name,
        desc: t.product_express_desc,
        specs: [
            t.product_express_spec1,
            t.product_express_spec2,
            t.product_express_spec3,
        ],
        badge: t.product_express_badge,
        href: "https://app.futureboard.studio",
        primary: false,
    },
    {
        index: "02",
        tag: t.product_lite_tag,
        name: t.product_lite_name,
        desc: t.product_lite_desc,
        specs: [
            t.product_lite_spec1,
            t.product_lite_spec2,
            t.product_lite_spec3,
        ],
        badge: t.product_lite_badge,
        href: null,
        primary: false,
    },
    {
        index: "03",
        tag: t.product_studio_tag,
        name: t.product_studio_name,
        desc: t.product_studio_desc,
        specs: [
            t.product_studio_spec1,
            t.product_studio_spec2,
            t.product_studio_spec3,
        ],
        badge: t.product_studio_badge,
        href: null,
        primary: true,
    },
] as const;
---

<section id="product" class="product-section">
    <div class="section-inner">
        <FadeUp client:visible>
            <span class="eyebrow">{t.product_eyebrow}</span>
            <h2 class="section-title">{t.product_title}</h2>
            <p class="section-lead">{t.product_lead}</p>
        </FadeUp>

        <div class="product-grid">
            {
                products.map((p) => {
                    const Tag = p.href ? "a" : "div";
                    const linkProps = p.href
                        ? {
                              href: p.href,
                              target: "_blank",
                              rel: "noopener noreferrer",
                          }
                        : {};
                    return (
                        <Tag
                            class:list={[
                                "product-card",
                                p.primary && "product-card--primary",
                                p.href && "product-card--link",
                            ]}
                            {...linkProps}
                        >
                            {p.primary && (
                                <span
                                    class="product-card-top"
                                    aria-hidden="true"
                                />
                            )}
                            <div class="product-card-head">
                                <span class="product-index">{p.index}</span>
                                <span
                                    class:list={[
                                        "product-tag",
                                        p.primary && "product-tag--accent",
                                    ]}
                                >
                                    {p.tag}
                                </span>
                            </div>
                            <h3 class="product-name">{p.name}</h3>
                            <p class="product-desc">{p.desc}</p>
                            <ul class="product-specs">
                                {p.specs.map((s) => (
                                    <li>
                                        <span
                                            class:list={[
                                                "spec-mark",
                                                p.primary && "spec-mark--accent",
                                            ]}
                                            aria-hidden="true"
                                        />
                                        {s}
                                    </li>
                                ))}
                            </ul>
                            <span
                                class:list={[
                                    "product-badge",
                                    p.primary && "product-badge--accent",
                                ]}
                            >
                                {p.badge}
                                {p.href && (
                                    <span class="product-badge-arrow" aria-hidden="true">
                                        ↗
                                    </span>
                                )}
                            </span>
                        </Tag>
                    );
                })
            }
        </div>
    </div>
</section>

<style>
    .product-section {
        background: var(--color-canvas);
        border-top: 1px solid var(--color-hairline);
        padding-block: 88px;
        padding-inline: 24px;
    }

    .section-lead {
        margin-bottom: 44px;
    }

    /* Bordered grid: shared 1px rules separate the columns */
    .product-grid {
        display: grid;
        grid-template-columns: 1fr;
        border: 1px solid var(--color-hairline);
        border-radius: var(--radius-md);
        overflow: hidden;
    }

    @media (min-width: 900px) {
        .product-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    .product-card {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 14px;
        padding: 26px 24px;
        text-decoration: none;
        color: inherit;
        border-bottom: 1px solid var(--color-hairline);
        transition: background-color var(--transition-base);
    }

    .product-card:last-child {
        border-bottom: 0;
    }

    @media (min-width: 900px) {
        .product-card {
            border-bottom: 0;
            border-right: 1px solid var(--color-hairline);
        }
        .product-card:last-child {
            border-right: 0;
        }
    }

    .product-card--primary {
        background: var(--color-canvas-mid);
    }

    .product-card--link:hover,
    .product-card--primary:hover {
        background: rgba(255, 255, 255, 0.018);
    }

    .product-card-top {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: var(--color-accent);
    }

    .product-card-head {
        display: flex;
        align-items: baseline;
        gap: 10px;
    }

    .product-index {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--color-accent);
        font-variant-numeric: tabular-nums;
    }

    .product-tag {
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--color-mute);
    }

    .product-tag--accent {
        color: var(--color-accent-dark);
    }

    .product-name {
        font-size: 1.125rem;
        font-weight: 500;
        color: var(--color-ink);
        letter-spacing: -0.025em;
    }

    .product-desc {
        font-size: 0.8125rem;
        line-height: 1.65;
        color: var(--color-body);
        flex-grow: 1;
        overflow-wrap: anywhere;
    }

    .product-specs {
        display: flex;
        flex-direction: column;
        gap: 9px;
        margin-top: 6px;
    }

    .product-specs li {
        display: flex;
        align-items: center;
        gap: 9px;
        font-size: 0.8125rem;
        color: var(--color-body-strong);
        min-width: 0;
    }

    .spec-mark {
        width: 5px;
        height: 5px;
        background: var(--color-mute);
        flex-shrink: 0;
    }

    .spec-mark--accent {
        background: var(--color-accent);
    }

    .product-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        align-self: flex-start;
        max-width: 100%;
        overflow-wrap: anywhere;
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        letter-spacing: 0.04em;
        color: var(--color-mute);
        border: 1px solid var(--color-hairline);
        border-radius: var(--radius-xs);
        padding: 4px 9px;
    }

    .product-badge--accent {
        color: var(--color-accent-light);
        border-color: rgba(115, 191, 252, 0.28);
    }

    .product-badge-arrow {
        font-size: 0.75rem;
    }
</style>
