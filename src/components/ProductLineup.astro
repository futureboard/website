---
import FadeUp from './motion/FadeUp.tsx';
import CursorGlowCard from './CursorGlowCard.tsx';
---

<section id="product" class="product-section">
  <div class="section-inner">
    <FadeUp client:visible>
      <span class="eyebrow">Product Lineup</span>
      <h2 class="section-title">Three builds, one codebase.</h2>
      <p class="section-lead">
        The web version runs right now. The native build is where the real work is happening.
      </p>
    </FadeUp>

    <div class="product-grid">

      <!-- Express — Web -->
      <CursorGlowCard
        as="a"
        href="https://app.futureboard.studio"
        target="_blank"
        rel="noopener noreferrer"
        className="product-card product-card--link"
        client:visible
      >
        <div class="product-card-header">
          <span class="product-tag">Express</span>
          <h3 class="product-name">Futureboard Express</h3>
        </div>
        <p class="product-desc">
          Runs in the browser, no install. Good for quick sketching and sharing ideas.
          React + WASM under the hood — not as fast as native, but surprisingly usable.
        </p>
        <ul class="product-specs">
          <li><span class="spec-dot" style="background: var(--color-sage);"></span>Runs in browser</li>
          <li><span class="spec-dot" style="background: var(--color-sage);"></span>React + WASM</li>
          <li><span class="spec-dot" style="background: var(--color-sage);"></span>No install needed</li>
        </ul>
        <span class="product-badge">Web target &rarr;</span>
      </CursorGlowCard>

      <!-- Lite — Electron -->
      <CursorGlowCard className="product-card product-card--muted" client:visible>
        <div class="product-card-header">
          <span class="product-tag">Lite</span>
          <h3 class="product-name">Futureboard Lite</h3>
        </div>
        <p class="product-desc">
          An installable app built on Electron. Easier to ship cross-platform but it has the usual
          overhead you'd expect. Solid middle ground while the native build matures.
        </p>
        <ul class="product-specs">
          <li><span class="spec-dot" style="background: var(--color-wheat);"></span>Electron desktop</li>
          <li><span class="spec-dot" style="background: var(--color-wheat);"></span>Windows / macOS / Linux</li>
          <li><span class="spec-dot" style="background: var(--color-wheat);"></span>Installable app</li>
        </ul>
        <span class="product-badge product-badge--muted">Electron target</span>
      </CursorGlowCard>

      <!-- Studio — Primary -->
      <CursorGlowCard className="product-card product-card--primary" client:visible>
        <div class="product-card-top-line" aria-hidden="true"></div>
        <div class="product-card-header">
          <span class="product-tag product-tag--accent">Studio</span>
          <h3 class="product-name">Futureboard Studio</h3>
        </div>
        <p class="product-desc">
          This is the one I actually care about. Rust + GPUI means native performance,
          zero electron overhead, and a UI that renders at GPU speed. Still in progress,
          but it's where most of the effort goes.
        </p>
        <ul class="product-specs">
          <li><span class="spec-dot spec-dot--accent"></span>Rust + GPUI</li>
          <li><span class="spec-dot spec-dot--accent"></span>Native audio engine</li>
          <li><span class="spec-dot spec-dot--accent"></span>GPU-rendered UI</li>
        </ul>
        <span class="product-badge product-badge--accent">Native target &middot; Primary</span>
      </CursorGlowCard>

    </div>
  </div>
</section>

<style>
  .product-section {
    background: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
    padding-block: 88px;
    padding-inline: 24px;
  }

  .section-lead {
    margin-bottom: 48px;
  }

  .product-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 768px) {
    .product-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Target both class types to preserve layout */
  :global(.cursor-glow-card).product-card {
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    height: 100%;
    box-sizing: border-box;
  }

  /* Linked card hover glow adjust */
  :global(.cursor-glow-card).product-card--link:hover {
    border-color: rgba(91, 191, 181, 0.4);
  }

  /* Muted card (Lite) */
  :global(.cursor-glow-card).product-card--muted {
    opacity: 0.75;
  }

  /* Primary card (Studio) */
  :global(.cursor-glow-card).product-card--primary {
    background: var(--color-canvas-mid);
    border-color: rgba(91, 191, 181, 0.22);
  }

  /* Dynamic accent hover glow for Studio card */
  :global(.cursor-glow-card).product-card--primary:hover {
    border-color: rgba(91, 191, 181, 0.45);
  }

  /* Top accent line for primary */
  .product-card-top-line {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(91, 191, 181, 0.4) 50%, transparent 100%);
    z-index: 10;
  }

  /* Card header */
  .product-card-header {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .product-tag {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-mute);
  }

  .product-tag--accent {
    color: var(--color-accent-dark);
  }

  .product-name {
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--color-ink);
    letter-spacing: -0.025em;
  }

  /* Description */
  .product-desc {
    font-size: 0.8125rem;
    line-height: 1.65;
    color: var(--color-body);
    flex-grow: 1;
  }

  /* Specs list */
  .product-specs {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: auto;
  }

  .product-specs li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8125rem;
    color: var(--color-body);
  }

  .spec-dot {
    width: 5px;
    height: 5px;
    border-radius: 9999px;
    flex-shrink: 0;
  }

  .spec-dot--accent {
    background: var(--color-accent);
  }

  /* Badge */
  .product-badge {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-mute);
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-xs);
    padding: 4px 10px;
    align-self: flex-start;
  }

  .product-badge--muted {
    opacity: 0.6;
  }

  .product-badge--accent {
    color: var(--color-accent);
    background: rgba(91, 191, 181, 0.06);
    border-color: rgba(91, 191, 181, 0.18);
  }
</style>
