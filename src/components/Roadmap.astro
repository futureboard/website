---
import FadeUp from "./motion/FadeUp.tsx";
import { translations, type Locale } from "../i18n/translations";

interface Props {
    lang?: Locale;
}

const { lang = "en" } = Astro.props;
const t = translations[lang];

const items = [
    { status: "active", label: t.roadmap_item1_label, detail: t.roadmap_item1_detail },
    { status: "active", label: t.roadmap_item2_label, detail: t.roadmap_item2_detail },
    { status: "active", label: t.roadmap_item3_label, detail: t.roadmap_item3_detail },
    { status: "active", label: t.roadmap_item4_label, detail: t.roadmap_item4_detail },
    { status: "planned", label: t.roadmap_item5_label, detail: t.roadmap_item5_detail },
    { status: "planned", label: t.roadmap_item6_label, detail: t.roadmap_item6_detail },
    { status: "planned", label: t.roadmap_item7_label, detail: t.roadmap_item7_detail },
    { status: "future", label: t.roadmap_item8_label, detail: t.roadmap_item8_detail },
    { status: "future", label: t.roadmap_item9_label, detail: t.roadmap_item9_detail },
];

const statusMeta: Record<string, { label: string; chip: string }> = {
    active: { label: t.roadmap_status_active, chip: "state-chip--live" },
    planned: { label: t.roadmap_status_planned, chip: "state-chip--planned" },
    future: { label: t.roadmap_status_future, chip: "state-chip--future" },
};
---

<section id="roadmap" class="roadmap-section">
    <div class="section-inner">
        <FadeUp client:visible>
            <span class="eyebrow">{t.roadmap_eyebrow}</span>
            <h2 class="section-title">{t.roadmap_title}</h2>
            <p class="section-lead">{t.roadmap_lead}</p>
        </FadeUp>

        <ol class="roadmap-list">
            {
                items.map((item, index) => {
                    const meta = statusMeta[item.status];
                    return (
                        <li class="roadmap-row">
                            <div class="roadmap-rail">
                                <span class="roadmap-index">
                                    {String(index + 1).padStart(2, "0")}
                                </span>
                                <span class={`state-chip ${meta.chip}`}>
                                    {meta.label}
                                </span>
                            </div>
                            <div class="roadmap-content">
                                <h3 class="roadmap-row-title">{item.label}</h3>
                                <p class="roadmap-row-detail">{item.detail}</p>
                            </div>
                        </li>
                    );
                })
            }
        </ol>
    </div>
</section>

<style>
    .roadmap-section {
        background: var(--color-canvas);
        border-top: 1px solid var(--color-hairline);
        padding-block: 88px;
        padding-inline: 24px;
    }

    .section-lead {
        margin-bottom: 48px;
    }

    .roadmap-list {
        max-width: 860px;
        margin-inline: auto;
        border: 1px solid var(--color-hairline);
        border-radius: var(--radius-md);
        overflow: hidden;
    }

    .roadmap-row {
        display: grid;
        grid-template-columns: 1fr;
        gap: 8px;
        padding: 20px 22px;
        border-top: 1px solid var(--color-hairline);
        transition: background-color var(--transition-base);
    }

    .roadmap-row:first-child {
        border-top: 0;
    }

    .roadmap-row:hover {
        background: rgba(255, 255, 255, 0.015);
    }

    @media (min-width: 640px) {
        .roadmap-row {
            grid-template-columns: 148px 1fr;
            gap: 28px;
            align-items: start;
        }
    }

    .roadmap-rail {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    @media (min-width: 640px) {
        .roadmap-rail {
            flex-direction: column;
            align-items: flex-start;
            gap: 10px;
            padding-top: 2px;
        }
    }

    .roadmap-index {
        font-family: var(--font-mono);
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--color-accent);
        font-variant-numeric: tabular-nums;
    }

    .roadmap-content {
        min-width: 0;
    }

    .roadmap-row-title {
        font-size: 0.9375rem;
        font-weight: 500;
        color: var(--color-ink);
        letter-spacing: -0.015em;
        margin-bottom: 5px;
    }

    .roadmap-row-detail {
        font-size: 0.8125rem;
        line-height: 1.62;
        color: var(--color-body);
        max-width: 60ch;
    }

    /* Future items read quieter without relying on color alone */
    .roadmap-row:has(.state-chip--future) .roadmap-row-title {
        color: var(--color-body-strong);
    }
</style>
