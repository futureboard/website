---
import FadeUp from './motion/FadeUp.tsx';

const items = [
  { status: 'active',  label: 'Port to GPUI Native',              detail: 'Migrating rendering layer to Rust + GPUI for full native performance.' },
  { status: 'active',  label: 'Timeline system',                   detail: 'Track lanes, clip arrangement, transport controls, and loop regions.' },
  { status: 'active',  label: 'Audio / MIDI / Automation editors', detail: 'Piano roll, automation curves, and waveform clip editors.' },
  { status: 'planned', label: 'Audio plugin support',              detail: 'VST3 and CLAP host integration. Plugin scanner and process sandbox.' },
  { status: 'planned', label: 'Mixer and routing',                 detail: 'Full channel strip, aux sends, master bus, and flexible routing graph.' },
  { status: 'planned', label: 'Windows first release',             detail: 'First stable binary targeting Windows x64.' },
  { status: 'planned', label: 'Web React + WASM target',           detail: 'Futureboard Express browser edition with WASM audio engine.' },
  { status: 'future',  label: 'macOS / Linux support',             detail: 'Community contributor pathway for non-Windows platforms.' },
  { status: 'future',  label: 'LV2 / AU plugin formats',           detail: 'Expand plugin ecosystem coverage for Linux and macOS users.' },
];

const statusMeta: Record<string, { label: string; tagClass: string; dotClass: string }> = {
  active:  { label: 'In Progress', tagClass: 'status-tag--active', dotClass: 'dot--active' },
  planned: { label: 'Planned',     tagClass: 'status-tag--planned', dotClass: 'dot--planned' },
  future:  { label: 'Future',      tagClass: 'status-tag--future', dotClass: 'dot--future' },
};
---

<section id="roadmap" class="roadmap-section">
  <div class="section-inner">
    <FadeUp client:visible>
      <span class="eyebrow">Roadmap</span>
      <h2 class="section-title">What's getting built, roughly.</h2>
      <p class="section-lead">
        Order might shift. Things take longer than expected. But this is the general direction.
      </p>
    </FadeUp>

    <div class="roadmap-timeline">
      {items.map((item, index) => {
        const meta = statusMeta[item.status];
        return (
          <div class={`timeline-item timeline-item--${item.status}`}>
            {/* Left track line and node */}
            <div class="timeline-track">
              <div class={`timeline-dot-wrapper ${meta.dotClass}`}>
                <div class="timeline-dot-core"></div>
                {item.status === 'active' && <span class="pulse-glow"></span>}
              </div>
              {index < items.length - 1 && <div class="timeline-line"></div>}
            </div>

            {/* Content card */}
            <div class="timeline-content">
              <div class="timeline-header">
                <span class={`status-tag ${meta.tagClass}`}>{meta.label}</span>
              </div>
              <h3 class="timeline-card-title">{item.label}</h3>
              <p class="timeline-card-detail">{item.detail}</p>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .roadmap-section {
    background: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
    padding-block: 96px;
    padding-inline: 24px;
  }

  .section-lead {
    margin-bottom: 56px;
  }

  /* Timeline Grid */
  .roadmap-timeline {
    max-width: 800px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: relative;
  }

  .timeline-item {
    display: flex;
    gap: 24px;
    position: relative;
  }

  /* Left track styling */
  .timeline-track {
    width: 24px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .timeline-dot-wrapper {
    width: 14px;
    height: 14px;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 5;
    background: var(--color-canvas);
    border: 1.5px solid transparent;
  }

  .timeline-dot-core {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
  }

  /* Dot status variables */
  .dot--active {
    border-color: var(--color-accent);
  }
  .dot--active .timeline-dot-core {
    background: var(--color-accent);
  }

  .dot--planned {
    border-color: var(--color-wheat);
  }
  .dot--planned .timeline-dot-core {
    background: var(--color-wheat);
  }

  .dot--future {
    border-color: var(--color-hairline);
  }
  .dot--future .timeline-dot-core {
    background: var(--color-hairline);
  }

  /* Connection line */
  .timeline-line {
    position: absolute;
    top: 16px;
    bottom: -24px;
    width: 1px;
    background: var(--color-hairline);
    z-index: 1;
  }

  /* Active Pulse Glow Animation */
  .pulse-glow {
    position: absolute;
    inset: -4px;
    border-radius: 9999px;
    border: 1px solid var(--color-accent);
    opacity: 0;
    animation: timeline-pulse 2.2s infinite cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  @keyframes timeline-pulse {
    0% {
      transform: scale(0.85);
      opacity: 0.8;
    }
    100% {
      transform: scale(1.65);
      opacity: 0;
    }
  }

  /* Card content wrapper */
  .timeline-content {
    flex-grow: 1;
    background: rgba(255, 255, 255, 0.012);
    border: 1px solid var(--color-hairline-soft);
    border-radius: var(--radius-md);
    padding: 16px 20px;
    transition: border-color var(--transition-base), background-color var(--transition-base);
  }

  .timeline-content:hover {
    background: rgba(255, 255, 255, 0.02);
    border-color: var(--color-hairline);
  }

  .timeline-header {
    display: flex;
    align-items: center;
    margin-bottom: 8px;
  }

  /* Status label tags */
  .status-tag {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: var(--radius-xs);
    border: 1px solid transparent;
  }

  .status-tag--active {
    background: rgba(91, 191, 181, 0.08);
    border-color: rgba(91, 191, 181, 0.2);
    color: var(--color-accent);
  }

  .status-tag--planned {
    background: rgba(200, 169, 122, 0.08);
    border-color: rgba(200, 169, 122, 0.2);
    color: var(--color-wheat);
  }

  .status-tag--future {
    background: rgba(255, 255, 255, 0.02);
    border-color: var(--color-hairline);
    color: var(--color-mute);
  }

  .timeline-card-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink);
    letter-spacing: -0.015em;
    margin-bottom: 4px;
  }

  .timeline-card-detail {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-body);
  }
</style>
