---
import FadeUp from './motion/FadeUp.tsx';

const items = [
  { status: 'active',  label: 'Port to GPUI Native',              detail: 'Migrating rendering layer to Rust + GPUI for full native performance.' },
  { status: 'active',  label: 'Timeline system',                   detail: 'Track lanes, clip arrangement, transport controls, and loop regions.' },
  { status: 'active',  label: 'Audio / MIDI / Automation editors', detail: 'Piano roll, automation curves, and waveform clip editors.' },
  { status: 'planned', label: 'Audio plugin support',              detail: 'VST3 and CLAP host integration. Plugin scanner and process sandbox.' },
  { status: 'planned', label: 'Mixer and routing',                 detail: 'Full channel strip, aux sends, master bus, and flexible routing graph.' },
  { status: 'planned', label: 'Windows first release',             detail: 'First stable binary targeting Windows x64.' },
  { status: 'planned', label: 'Web React + WASM target',           detail: 'Futureboard Express browser edition with WASM audio engine.' },
  { status: 'future',  label: 'macOS / Linux support',             detail: 'Community contributor pathway for non-Windows platforms.' },
  { status: 'future',  label: 'LV2 / AU plugin formats',           detail: 'Expand plugin ecosystem coverage for Linux and macOS users.' },
];

const statusMeta: Record<string, { label: string; dotClass: string }> = {
  active:  { label: 'In progress', dotClass: 'dot--active' },
  planned: { label: 'Planned',     dotClass: 'dot--planned' },
  future:  { label: 'Future',      dotClass: 'dot--future' },
};
---

<section id="roadmap" class="roadmap-section">
  <div class="section-inner">
    <FadeUp client:visible>
      <span class="eyebrow">Roadmap</span>
      <h2 class="section-title">What's being built.</h2>
      <p class="section-lead">
        Futureboard is in active development. This is a living roadmap — priorities shift as the project grows.
      </p>
    </FadeUp>

    <div class="roadmap-list">
      {items.map((item) => {
        const meta = statusMeta[item.status];
        return (
          <div class="roadmap-row">
            <div class="roadmap-status">
              <span class={`status-dot ${meta.dotClass}`}></span>
              <span class="status-label">{meta.label}</span>
            </div>
            <div class="roadmap-content">
              <p class="roadmap-title">{item.label}</p>
              <p class="roadmap-detail">{item.detail}</p>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .roadmap-section {
    background: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
    padding-block: 88px;
    padding-inline: 24px;
  }

  .section-lead {
    margin-bottom: 40px;
  }

  /* List */
  .roadmap-list {
    border-top: 1px solid var(--color-hairline);
  }

  .roadmap-row {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    padding-block: 18px;
    border-bottom: 1px solid var(--color-hairline);
  }

  /* Status column */
  .roadmap-status {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 108px;
    flex-shrink: 0;
    padding-top: 2px;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    flex-shrink: 0;
  }

  .dot--active  { background: var(--color-accent); }
  .dot--planned { background: var(--color-wheat); }
  .dot--future  { background: var(--color-hairline-soft); border: 1px solid var(--color-hairline); width: 5px; height: 5px; }

  .status-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-mute);
    letter-spacing: 0.02em;
  }

  /* Content */
  .roadmap-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .roadmap-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink);
    letter-spacing: -0.01em;
  }

  .roadmap-detail {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-body);
  }
</style>
