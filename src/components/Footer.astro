---
const year = new Date().getFullYear();

const social = [
  {
    label: 'Discord',
    href: 'https://discord.gg/kcAmCyXnVn',
    // brand-discord — Tabler stroke path
    path: 'M8.5 5a13.2 13.2 0 0 0-5.5 1.6 14 14 0 0 0-2 9.9 13 13 0 0 0 5.5 2.5 10 10 0 0 0 .9-1.8 8.5 8.5 0 0 1-1.4-.7l.4-1a10.3 10.3 0 0 0 8.2 0l.4 1a8.5 8.5 0 0 1-1.4.7 10 10 0 0 0 .9 1.8 13 13 0 0 0 5.5-2.5 14 14 0 0 0-2-9.9A13.2 13.2 0 0 0 15.5 5h-7zM9.5 13a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z',
  },
  {
    label: 'X / Twitter',
    href: 'https://x.com/ftbdproject',
    // brand-x — Tabler stroke path
    path: 'M4 4l11.733 16H20L8.267 4zM4 20l6.768-6.768m2.46-2.46L20 4',
  },
  {
    label: 'Facebook',
    href: 'https://facebook.com/ftbdproject',
    // brand-facebook — Tabler stroke path
    path: 'M7 10h3V8a2 2 0 0 1 2-2h3v3h-2a1 1 0 0 0-1 1v2h3l-1 3h-2v7h-3v-7H7v-3z',
  },
];
---

<footer class="bg-canvas border-t border-hairline py-12 px-6">
  <div class="max-w-[1200px] mx-auto flex flex-col md:flex-row md:items-start justify-between gap-10">

    <!-- Brand -->
    <div class="flex flex-col gap-3 max-w-xs">
      <p class="text-ink text-sm font-medium">Futureboard Studio</p>
      <p class="text-body text-xs leading-5">
        A modern DAW and creative audio platform built with Rust, GPUI, Web, and native audio technology.
      </p>
      <p class="text-mute text-xs font-mono flex items-center gap-1.5">
        <span
          class="w-1.5 h-1.5 rounded-full inline-block flex-shrink-0"
          style="background:#58CBCB; box-shadow: 0 0 5px #58CBCB;"
        ></span>
        Experimental project in active development.
      </p>
    </div>

    <div class="flex flex-col sm:flex-row gap-10">
      <!-- Links -->
      <div class="flex flex-col gap-2">
        <p class="text-mute text-xs font-mono uppercase tracking-widest mb-1">Links</p>
        <a
          href="https://github.com/arizkami/futureboard"
          target="_blank"
          rel="noopener noreferrer"
          class="text-body text-sm hover:text-ink transition-colors"
        >
          GitHub
        </a>
        <a
          href="#waitlist"
          class="text-body text-sm hover:text-ink transition-colors"
        >
          Join Waitlist
        </a>
      </div>

      <!-- Community / Social -->
      <div class="flex flex-col gap-2">
        <p class="text-mute text-xs font-mono uppercase tracking-widest mb-1">Community</p>
        {social.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-body text-sm hover:text-ink transition-colors group"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="opacity-60 group-hover:opacity-100 transition-opacity flex-shrink-0"
              aria-hidden="true"
            >
              <path d={s.path} />
            </svg>
            {s.label}
          </a>
        ))}
      </div>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="max-w-[1200px] mx-auto mt-10 pt-6 border-t border-hairline flex flex-col md:flex-row md:items-center justify-between gap-2">
    <p class="text-mute text-xs">
      &copy; {year} Futureboard Studio. MIT License.
    </p>
    <p class="text-mute text-xs">
      Built with Astro &middot; Rust &middot; GPUI
    </p>
  </div>
</footer>
