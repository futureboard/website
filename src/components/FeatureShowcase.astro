---
import FadeUp from './motion/FadeUp.tsx';
import { translations, type Locale } from '../i18n/translations';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const t = translations[lang];

const features = [
  {
    id: 'track-experience',
    tag: '01',
    title: t.ft_track_title,
    body: [t.ft_track_body1, t.ft_track_body2],
    image: '/ft-track-experience.webp',
    imageAlt: 'Futureboard track arrangement view showing multiple colored audio tracks',
    flip: false,
    accent: '#31FD97',
  },
  {
    id: 'inspector',
    tag: '02',
    title: t.ft_inspector_title,
    body: [t.ft_inspector_body1, t.ft_inspector_body2],
    image: '/ft-inspector.webp',
    imageAlt: 'Inspector panel showing clip properties like name, timing, gain, and fade controls',
    flip: true,
    accent: '#73BFFC',
  },
  {
    id: 'continuous-scroll',
    tag: '03',
    title: t.ft_scroll_title,
    body: [t.ft_scroll_body1, t.ft_scroll_body2],
    image: '/ft-continuous-scroll.webp',
    imageAlt: 'Continuous scroll view showing smooth waveform timeline playback',
    flip: false,
    accent: '#94E2FE',
  },
  {
    id: 'floating-toolbar',
    tag: '04',
    title: t.ft_toolbar_title,
    body: [t.ft_toolbar_body1, t.ft_toolbar_body2],
    image: '/ft-floating-toolbar.webp',
    imageAlt: 'Floating toolbar appearing near an audio track with editing tool icons',
    flip: true,
    accent: '#FCA2B2',
  },
  {
    id: 'mixer',
    tag: '05',
    title: t.ft_mixer_title,
    body: [t.ft_mixer_body1, t.ft_mixer_body2],
    image: '/ft-mixer.webp',
    imageAlt: 'Futureboard mixer showing multiple channel strips with faders, pan knobs, and meters',
    flip: false,
    accent: '#CD96FE',
  },
  {
    id: 'midi-editor',
    tag: '06',
    title: t.ft_midi_title,
    body: [t.ft_midi_body1, t.ft_midi_body2],
    image: '/ft-midi.webp',
    imageAlt: 'MIDI piano roll editor showing teal note blocks on a dark grid',
    flip: true,
    accent: '#7163F6',
  },
];
---

<section id="feature-showcase" class="showcase-section">
  <div class="section-inner">
    <FadeUp client:visible>
      <span class="eyebrow">{t.features_eyebrow}</span>
      <h2 class="section-title">{t.features_title}</h2>
      <p class="section-lead">{t.features_lead}</p>
    </FadeUp>
  </div>

  <div class="showcase-features">
    {features.map((ft, i) => (
      <article
        class={`showcase-item ${ft.flip ? 'showcase-item--flip' : ''}`}
        id={ft.id}
        style={`--ft-accent: ${ft.accent};`}
      >
        <div class="showcase-inner">
          <!-- Text column -->
          <div class="showcase-text">
            <div class="showcase-meta">
              <span class="showcase-num">{ft.tag}</span>
              <span class="showcase-divider" aria-hidden="true"></span>
            </div>
            <h3 class="showcase-title">{ft.title}</h3>
            {ft.body.map(p => (
              <p class="showcase-body">{p}</p>
            ))}
          </div>

          <!-- Image column with stylized editor window frame -->
          <div class="showcase-visual">
            <div class="showcase-frame">
              <div class="frame-header-decor">
                <span class="decor-dot"></span>
                <span class="decor-title">{ft.title.toUpperCase()} PANEL</span>
                <span class="decor-ruler">0{i + 1}:00:00:00</span>
              </div>
              <div class="frame-glow" aria-hidden="true"></div>
              <img
                src={ft.image}
                alt={ft.imageAlt}
                class="showcase-img"
                loading={i === 0 ? 'eager' : 'lazy'}
              />
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  /* ─── Section wrapper ─────────────────────────── */
  .showcase-section {
    background: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
    padding-block: 96px 0;
  }

  .showcase-section .section-inner {
    padding-inline: 24px;
    margin-bottom: 80px;
  }

  .section-lead {
    margin-top: 0.75rem;
  }

  /* ─── Feature items list ──────────────────────── */
  .showcase-features {
    display: flex;
    flex-direction: column;
  }

  /* ─── Each item ───────────────────────────────── */
  .showcase-item {
    border-top: 1px solid var(--color-hairline);
    padding-block: 80px;
    padding-inline: 24px;
    position: relative;
    transition: background 0.4s ease;
  }

  .showcase-item:last-child {
    border-bottom: 1px solid var(--color-hairline);
  }

  /* Subtle accent glow on hover per-item */
  .showcase-item::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.012);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    z-index: 0;
  }

  .showcase-item--flip::before {
    background: rgba(255, 255, 255, 0.012);
  }

  .showcase-item:hover::before {
    opacity: 1;
  }

  /* ─── Inner grid ──────────────────────────────── */
  .showcase-inner {
    max-width: 1200px;
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  @media (min-width: 900px) {
    .showcase-inner {
      grid-template-columns: 1fr 1fr;
      gap: 72px;
    }

    /* Flip layout: image left, text right */
    .showcase-item--flip .showcase-inner {
      direction: rtl;
    }

    .showcase-item--flip .showcase-inner > * {
      direction: ltr;
    }
  }

  /* ─── Text column ─────────────────────────────── */
  .showcase-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
  }

  .showcase-num {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--ft-accent);
    opacity: 0.85;
  }

  .showcase-divider {
    display: block;
    height: 1px;
    width: 32px;
    background: var(--ft-accent);
    opacity: 0.3;
    flex-shrink: 0;
  }

  .showcase-title {
    font-size: clamp(1.5rem, 3vw, 2.125rem);
    font-weight: 400;
    letter-spacing: -0.04em;
    color: var(--color-ink);
    line-height: 1.12;
    margin-bottom: 20px;
  }

  .showcase-body {
    font-size: 0.9375rem;
    line-height: 1.78;
    color: var(--color-body);
    max-width: 48ch;
  }

  .showcase-body + .showcase-body {
    margin-top: 14px;
  }

  /* ─── Image column ────────────────────────────── */
  .showcase-visual {
    position: relative;
  }

  .showcase-frame {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-hairline);
    background: var(--color-canvas-soft);
    box-shadow: 0 10px 28px rgba(0,0,0,0.28);
  }

  .frame-header-decor {
    background: var(--color-canvas-mid);
    border-bottom: 1px solid var(--color-hairline-soft);
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-inline: 12px;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--color-mute);
    letter-spacing: 0.06em;
    user-select: none;
  }

  .decor-dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: var(--ft-accent);
    box-shadow: none;
  }

  .decor-title {
    color: var(--color-body-strong);
  }

  .decor-ruler {
    font-variant-numeric: tabular-nums;
  }

  /* Per-item accent glow behind frame */
  .frame-glow {
    position: absolute;
    inset: -40px;
    border-radius: 50%;
    background: transparent;
    z-index: -1;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .showcase-img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    /* Subtle entrance on load */
    transition: transform 0.6s ease, filter 0.4s ease;
    filter: brightness(0.92) saturate(0.95);
  }

  .showcase-frame:hover .showcase-img {
    transform: scale(1.015);
    filter: brightness(1) saturate(1);
  }

  /* ─── Responsive tweaks ───────────────────────── */
  @media (max-width: 899px) {
    .showcase-item {
      padding-block: 56px;
    }

    .showcase-inner {
      gap: 32px;
    }

    /* On mobile, always show text first */
    .showcase-text {
      order: 1;
    }

    .showcase-visual {
      order: 2;
    }

    .showcase-body {
      max-width: 100%;
    }
  }
</style>
