---
import FadeUp from './motion/FadeUp.tsx';
import { translations, type Locale } from '../i18n/translations';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const t = translations[lang];

const features = [
  {
    id: 'track-experience',
    tag: '01',
    title: t.ft_track_title,
    body: [t.ft_track_body1, t.ft_track_body2],
    image: '/ft-track-experience.webp',
    imageAlt: 'Futureboard track arrangement view showing multiple colored audio tracks',
    flip: false,
  },
  {
    id: 'inspector',
    tag: '02',
    title: t.ft_inspector_title,
    body: [t.ft_inspector_body1, t.ft_inspector_body2],
    image: '/ft-inspector.webp',
    imageAlt: 'Inspector panel showing clip properties like name, timing, gain, and fade controls',
    flip: true,
  },
  {
    id: 'continuous-scroll',
    tag: '03',
    title: t.ft_scroll_title,
    body: [t.ft_scroll_body1, t.ft_scroll_body2],
    image: '/ft-continuous-scroll.webp',
    imageAlt: 'Continuous scroll view showing smooth waveform timeline playback',
    flip: false,
  },
  {
    id: 'floating-toolbar',
    tag: '04',
    title: t.ft_toolbar_title,
    body: [t.ft_toolbar_body1, t.ft_toolbar_body2],
    image: '/ft-floating-toolbar.webp',
    imageAlt: 'Floating toolbar appearing near an audio track with editing tool icons',
    flip: true,
  },
  {
    id: 'mixer',
    tag: '05',
    title: t.ft_mixer_title,
    body: [t.ft_mixer_body1, t.ft_mixer_body2],
    image: '/ft-mixer.webp',
    imageAlt: 'Futureboard mixer showing multiple channel strips with faders, pan knobs, and meters',
    flip: false,
  },
  {
    id: 'midi-editor',
    tag: '06',
    title: t.ft_midi_title,
    body: [t.ft_midi_body1, t.ft_midi_body2],
    image: '/ft-midi.webp',
    imageAlt: 'MIDI piano roll editor showing teal note blocks on a dark grid',
    flip: true,
  },
];
---

<section id="feature-showcase" class="showcase-section">
  <div class="section-inner">
    <FadeUp client:visible>
      <span class="eyebrow">{t.features_eyebrow}</span>
      <h2 class="section-title">{t.features_title}</h2>
      <p class="section-lead">{t.features_lead}</p>
    </FadeUp>
  </div>

  <div class="showcase-features">
    {features.map((ft, i) => (
      <article
        class={`showcase-item ${ft.flip ? 'showcase-item--flip' : ''}`}
        id={ft.id}
      >
        <div class="showcase-inner">
          <!-- Text column -->
          <div class="showcase-text">
            <div class="showcase-meta">
              <span class="showcase-num">{ft.tag}</span>
              <span class="showcase-divider" aria-hidden="true"></span>
              <span class="showcase-kicker">{ft.id.replace(/-/g, ' ')}</span>
            </div>
            <h3 class="showcase-title">{ft.title}</h3>
            {ft.body.map(p => (
              <p class="showcase-body">{p}</p>
            ))}
          </div>

          <!-- Image column, framed with mono panel header -->
          <div class="showcase-visual">
            <figure class="showcase-frame">
              <figcaption class="frame-bar">
                <span class="frame-bar-name">{ft.title.toUpperCase()}</span>
                <span class="frame-bar-code">{`0${i + 1}:00:00:00`}</span>
              </figcaption>
              <img
                src={ft.image}
                alt={ft.imageAlt}
                class="showcase-img"
                loading={i === 0 ? 'eager' : 'lazy'}
              />
            </figure>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .showcase-section {
    background: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
    padding-block: 96px 0;
  }

  .showcase-section .section-inner {
    padding-inline: 24px;
    margin-bottom: 72px;
  }

  .showcase-features {
    display: flex;
    flex-direction: column;
  }

  .showcase-item {
    border-top: 1px solid var(--color-hairline);
    padding-block: 72px;
    padding-inline: 24px;
    position: relative;
  }

  .showcase-item:last-child {
    border-bottom: 1px solid var(--color-hairline);
  }

  .showcase-inner {
    max-width: 1200px;
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
    position: relative;
  }

  @media (min-width: 900px) {
    .showcase-inner {
      grid-template-columns: 1fr 1fr;
      gap: 64px;
    }

    .showcase-item--flip .showcase-inner {
      direction: rtl;
    }

    .showcase-item--flip .showcase-inner > * {
      direction: ltr;
    }
  }

  /* Text column */
  .showcase-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
  }

  .showcase-num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
  }

  .showcase-divider {
    display: block;
    height: 1px;
    width: 28px;
    background: var(--color-hairline);
    flex-shrink: 0;
  }

  .showcase-kicker {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-mute);
  }

  .showcase-title {
    font-size: clamp(1.5rem, 3vw, 2.125rem);
    font-weight: 400;
    letter-spacing: -0.04em;
    color: var(--color-ink);
    line-height: 1.12;
    margin-bottom: 20px;
  }

  .showcase-body {
    font-size: 0.9375rem;
    line-height: 1.78;
    color: var(--color-body);
    max-width: 48ch;
  }

  .showcase-body + .showcase-body {
    margin-top: 14px;
  }

  /* Image column */
  .showcase-visual {
    position: relative;
  }

  .showcase-frame {
    margin: 0;
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-hairline);
    background: var(--color-canvas-soft);
    box-shadow: var(--shadow-md);
  }

  .frame-bar {
    background: var(--color-canvas-mid);
    border-bottom: 1px solid var(--color-hairline-soft);
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-inline: 12px;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.06em;
    color: var(--color-mute);
    user-select: none;
  }

  .frame-bar-name {
    color: var(--color-body-strong);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .frame-bar-code {
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }

  .showcase-img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    filter: brightness(0.95);
  }

  @media (max-width: 899px) {
    .showcase-item {
      padding-block: 52px;
    }

    .showcase-inner {
      gap: 28px;
    }

    .showcase-text {
      order: 1;
    }

    .showcase-visual {
      order: 2;
    }

    .showcase-body {
      max-width: 100%;
    }
  }
</style>
