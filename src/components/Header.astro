---
---

<header class="sticky top-0 z-50 bg-canvas border-b border-hairline backdrop-blur-sm">
  <nav class="max-w-[1200px] mx-auto px-6 flex items-center justify-between h-12">

    <!-- Wordmark -->
    <a href="/" class="text-ink text-sm font-medium tracking-tight hover:text-accent transition-colors">
      Futureboard Studio
    </a>

    <!-- Desktop nav links -->
    <ul class="hidden md:flex items-center gap-1" role="list">
      <li>
        <a href="/#product" class="text-body text-sm font-medium px-2.5 py-1 rounded-sm hover:text-ink transition-colors">
          Product
        </a>
      </li>
      <li>
        <a href="/#features" class="text-body text-sm font-medium px-2.5 py-1 rounded-sm hover:text-ink transition-colors">
          Features
        </a>
      </li>
      <li>
        <a href="/#roadmap" class="text-body text-sm font-medium px-2.5 py-1 rounded-sm hover:text-ink transition-colors">
          Roadmap
        </a>
      </li>
    </ul>

    <!-- Right cluster -->
    <div class="flex items-center gap-1">

      <!-- Social icon buttons (desktop) -->
      <div class="hidden md:flex items-center gap-0.5 mr-2">

        <!-- Discord -->
        <a
          href="https://discord.gg/kcAmCyXnVn"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Join our Discord"
          class="flex items-center justify-center w-8 h-8 rounded-sm text-mute hover:text-ink transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M8.5 5a13.2 13.2 0 0 0-5.5 1.6 14 14 0 0 0-2 9.9 13 13 0 0 0 5.5 2.5 10 10 0 0 0 .9-1.8 8.5 8.5 0 0 1-1.4-.7l.4-1a10.3 10.3 0 0 0 8.2 0l.4 1a8.5 8.5 0 0 1-1.4.7 10 10 0 0 0 .9 1.8 13 13 0 0 0 5.5-2.5 14 14 0 0 0-2-9.9A13.2 13.2 0 0 0 15.5 5h-7zM9.5 13a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z" />
          </svg>
        </a>

        <!-- X / Twitter -->
        <a
          href="https://x.com/ftbdproject"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Follow us on X"
          class="flex items-center justify-center w-8 h-8 rounded-sm text-mute hover:text-ink transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4l11.733 16H20L8.267 4zM4 20l6.768-6.768m2.46-2.46L20 4" />
          </svg>
        </a>

        <!-- GitHub -->
        <a
          href="https://github.com/arizkami/futureboard"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="View on GitHub"
          class="flex items-center justify-center w-8 h-8 rounded-sm text-mute hover:text-ink transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
          </svg>
        </a>

      </div>

      <!-- CTA -->
      <a
        href="/#waitlist"
        class="inline-flex items-center bg-accent text-canvas text-sm font-medium px-4 py-2 rounded-sm hover:bg-accent-light transition-colors"
        style="box-shadow: 0 0 12px rgba(88, 203, 203, 0.2);"
      >
        Join Waitlist
      </a>

    </div>
  </nav>
</header>
