---
import { translations, type Locale } from "../i18n/translations";
import LanguageSwitcher from "./LanguageSwitcher";

interface Props {
    lang?: Locale;
}

const { lang = "en" } = Astro.props;
const t = translations[lang];
const WAITLIST_URL = "https://tally.so/r/lbgzx5";

// Get pathname to dynamically switch language pages
const pathname = Astro.url.pathname;
let cleanPath = pathname;

// Strip out existing locale prefixes to get clean path
if (
    pathname.startsWith("/th/") ||
    pathname.startsWith("/ja/") ||
    pathname.startsWith("/zh/")
) {
    cleanPath = pathname.substring(3);
} else if (pathname === "/th" || pathname === "/ja" || pathname === "/zh") {
    cleanPath = "/";
}
---

<a href="#main-content" class="skip-link">{t.nav_skip}</a>
<header class="site-header">
    <nav class="site-nav section-inner">
        <!-- Wordmark & Stylized Logo -->
        <div class="header-left">
            <a href={lang === "en" ? "/" : `/${lang}`} class="wordmark-link">
                <img src="/logo.svg" alt="" class="h-5" />
            </a>
        </div>

        <!-- Desktop nav links -->
        <ul class="nav-links" role="list">
            <li>
                <a href={lang === "en" ? "/#product" : `/${lang}#product`}
                    >{t.nav_product}</a
                >
            </li>
            <li>
                <a
                    href={lang === "en"
                        ? "/#feature-showcase"
                        : `/${lang}#feature-showcase`}>{t.nav_features}</a
                >
            </li>
            <li>
                <a href={lang === "en" ? "/#roadmap" : `/${lang}#roadmap`}
                    >{t.nav_roadmap}</a
                >
            </li>
            <li>
                <a href={lang === "en" ? "/download" : `/${lang}/download`}
                    >{t.nav_download}</a
                >
            </li>
            <li>
                <a href={lang === "en" ? "/pricing" : `/${lang}/pricing`}
                    >{t.nav_pricing}</a
                >
            </li>
            <li>
                <a href={lang === "en" ? "/blogs" : `/${lang}/blogs`}
                    >{t.nav_blog}</a
                >
            </li>
        </ul>

        <!-- Right cluster -->
        <div class="nav-actions">
            <!-- Social icons -->
            <div class="social-icons">
                <!-- Discord -->
                <a
                    href="https://discord.gg/kcAmCyXnVn"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Join our Discord"
                    class="icon-btn"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.75"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <path
                            d="M8.5 5a13.2 13.2 0 0 0-5.5 1.6 14 14 0 0 0-2 9.9 13 13 0 0 0 5.5 2.5 10 10 0 0 0 .9-1.8 8.5 8.5 0 0 1-1.4-.7l.4-1a10.3 10.3 0 0 0 8.2 0l.4 1a8.5 8.5 0 0 1-1.4.7 10 10 0 0 0 .9 1.8 13 13 0 0 0 5.5-2.5 14 14 0 0 0-2-9.9A13.2 13.2 0 0 0 15.5 5h-7zM9.5 13a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"
                        ></path>
                    </svg>
                </a>

                <!-- X / Twitter -->
                <a
                    href="https://x.com/ftbdproject"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Follow us on X"
                    class="icon-btn"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="15"
                        height="15"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.75"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <path
                            d="M4 4l11.733 16H20L8.267 4zM4 20l6.768-6.768m2.46-2.46L20 4"
                        ></path>
                    </svg>
                </a>

                <!-- GitHub -->
                <a
                    href="https://github.com/arizkami/futureboard"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="View on GitHub"
                    class="icon-btn"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.75"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <path
                            d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
                        ></path>
                    </svg>
                </a>
            </div>

            <!-- Language selector dropdown -->
            <LanguageSwitcher
                client:load
                currentLang={lang}
                cleanPath={cleanPath}
            />

            <!-- CTA -->
            <a
                href={WAITLIST_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-primary nav-cta"
            >
                {t.nav_waitlist}
            </a>

            <button
                type="button"
                class="mobile-menu-toggle"
                aria-label="Open navigation menu"
                aria-expanded="false"
                aria-controls="mobile-sidebar"
                data-mobile-menu-toggle
            >
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
    </nav>

    <div class="mobile-sidebar-backdrop" data-mobile-menu-close></div>
    <aside
        id="mobile-sidebar"
        class="mobile-sidebar"
        aria-label="Mobile navigation"
        aria-hidden="true"
    >
        <div class="mobile-sidebar-header">
            <a href={lang === "en" ? "/" : `/${lang}`} class="wordmark-link">
                <img src="/logo.svg" alt="Futureboard" class="h-5" />
            </a>
            <button
                type="button"
                class="mobile-sidebar-close"
                aria-label="Close navigation menu"
                data-mobile-menu-close
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <path d="M18 6 6 18"></path>
                    <path d="m6 6 12 12"></path>
                </svg>
            </button>
        </div>

        <nav class="mobile-sidebar-nav" aria-label="Mobile primary navigation">
            <a href={lang === "en" ? "/#product" : `/${lang}#product`}
                >{t.nav_product}</a
            >
            <a
                href={lang === "en"
                    ? "/#feature-showcase"
                    : `/${lang}#feature-showcase`}>{t.nav_features}</a
            >
            <a href={lang === "en" ? "/#roadmap" : `/${lang}#roadmap`}
                >{t.nav_roadmap}</a
            >
            <a href={lang === "en" ? "/download" : `/${lang}/download`}
                >{t.nav_download}</a
            >
            <a href={lang === "en" ? "/pricing" : `/${lang}/pricing`}
                >{t.nav_pricing}</a
            >
            <a href={lang === "en" ? "/blogs" : `/${lang}/blogs`}
                >{t.nav_blog}</a
            >
        </nav>

        <div class="mobile-sidebar-actions">
            <a
                href={WAITLIST_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-primary mobile-sidebar-cta"
            >
                {t.nav_waitlist}
            </a>
            <div class="mobile-sidebar-socials" aria-label="Social links">
                <a
                    href="https://discord.gg/kcAmCyXnVn"
                    target="_blank"
                    rel="noopener noreferrer">Discord</a
                >
                <a
                    href="https://x.com/ftbdproject"
                    target="_blank"
                    rel="noopener noreferrer">X</a
                >
                <a
                    href="https://github.com/arizkami/futureboard"
                    target="_blank"
                    rel="noopener noreferrer">GitHub</a
                >
            </div>
        </div>
    </aside>
</header>

<script>
    const header = document.querySelector(".site-header");
    const sidebar = document.querySelector(".mobile-sidebar");
    const toggle = document.querySelector("[data-mobile-menu-toggle]");
    const closeTargets = document.querySelectorAll("[data-mobile-menu-close]");
    const sidebarLinks = document.querySelectorAll(".mobile-sidebar a");

    const setMobileMenuOpen = (open) => {
        header?.toggleAttribute("data-mobile-menu-open", open);
        sidebar?.setAttribute("aria-hidden", String(!open));
        toggle?.setAttribute("aria-expanded", String(open));
        document.body.style.overflow = open ? "hidden" : "";
    };

    toggle?.addEventListener("click", () => {
        setMobileMenuOpen(!header?.hasAttribute("data-mobile-menu-open"));
    });

    closeTargets.forEach((target) => {
        target.addEventListener("click", () => setMobileMenuOpen(false));
    });

    sidebarLinks.forEach((link) => {
        link.addEventListener("click", () => setMobileMenuOpen(false));
    });

    document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") setMobileMenuOpen(false);
    });

    window.addEventListener("resize", () => {
        if (window.innerWidth >= 920) setMobileMenuOpen(false);
    });

    // Scrollspy: mark the nav link for the section currently in view.
    const spySections = ["product", "feature-showcase", "roadmap", "waitlist"]
        .map((id) => document.getElementById(id))
        .filter(Boolean);

    if (spySections.length && "IntersectionObserver" in window) {
        const navAnchors = Array.from(
            document.querySelectorAll(".nav-links a, .mobile-sidebar-nav a"),
        );
        const linkFor = (id) =>
            navAnchors.filter((a) =>
                (a.getAttribute("href") || "").endsWith("#" + id),
            );

        const setCurrent = (id) => {
            navAnchors.forEach((a) => a.removeAttribute("aria-current"));
            if (id)
                linkFor(id).forEach((a) =>
                    a.setAttribute("aria-current", "true"),
                );
        };

        const observer = new IntersectionObserver(
            (entries) => {
                const visible = entries
                    .filter((e) => e.isIntersecting)
                    .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
                if (visible) setCurrent(visible.target.id);
            },
            { rootMargin: "-45% 0px -45% 0px", threshold: 0 },
        );

        spySections.forEach((section) => observer.observe(section));
    }
</script>

<style>
    .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
    }

    .site-header::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: -1;
        background: var(--color-canvas);
        border-bottom: 1px solid var(--color-hairline);
    }

    .site-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 52px;
    }

    .header-left {
        display: flex;
        align-items: center;
    }

    /* Wordmark link */
    .wordmark-link {
        display: flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

    .site-logo {
        flex-shrink: 0;
        transition: transform var(--transition-fast);
    }

    .wordmark-link:hover .site-logo {
        transform: scale(1.05);
    }

    /* Wordmark text */
    .wordmark {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--color-ink);
        letter-spacing: -0.015em;
        transition: color var(--transition-fast);
    }

    .wordmark-link:hover .wordmark {
        color: var(--color-accent);
    }

    /* Nav links */
    .nav-links {
        display: none;
        align-items: center;
        gap: 4px;
    }

    @media (min-width: 920px) {
        .nav-links {
            display: flex;
        }
    }

    .nav-links a {
        font-size: 0.875rem;
        font-weight: 400;
        color: var(--color-body);
        padding: 4px 10px;
        border-radius: var(--radius-sm);
        transition:
            color var(--transition-fast),
            background-color var(--transition-fast);
    }

    .nav-links a:hover {
        color: var(--color-ink);
        background-color: rgba(255, 255, 255, 0.035);
    }

    .nav-links a[aria-current="true"] {
        color: var(--color-ink);
        background-color: rgba(255, 255, 255, 0.045);
        box-shadow: inset 0 -1px 0 var(--color-accent);
    }

    .mobile-sidebar-nav a[aria-current="true"] {
        color: var(--color-ink);
        background: rgba(255, 255, 255, 0.045);
        box-shadow: inset 2px 0 0 var(--color-accent);
    }

    /* Right actions */
    .nav-actions {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* Social icons */
    .social-icons {
        display: none;
        align-items: center;
        gap: 2px;
        margin-right: 4px;
    }

    @media (min-width: 920px) {
        .social-icons {
            display: flex;
        }
    }

    .icon-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: var(--radius-sm);
        color: var(--color-mute);
        transition:
            color var(--transition-fast),
            background-color var(--transition-fast);
    }

    .icon-btn:hover {
        color: var(--color-body-strong);
        background-color: rgba(255, 255, 255, 0.035);
    }

    /* CTA */
    .nav-cta {
        font-size: 0.8125rem;
        padding: 7px 14px;
        white-space: nowrap;
    }

    .mobile-menu-toggle {
        display: inline-flex;
        width: 34px;
        height: 34px;
        flex-shrink: 0;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 4px;
        border: 1px solid var(--color-hairline);
        border-radius: var(--radius-sm);
        background: rgba(255, 255, 255, 0.025);
        color: var(--color-ink);
        transition:
            border-color var(--transition-fast),
            background-color var(--transition-fast);
    }

    .mobile-menu-toggle:hover {
        border-color: var(--color-rim, var(--fb-rim));
        background: rgba(255, 255, 255, 0.055);
    }

    .mobile-menu-toggle span {
        width: 14px;
        height: 1.5px;
        border-radius: 9999px;
        background: currentColor;
        transition:
            transform var(--transition-fast),
            opacity var(--transition-fast);
    }

    .site-header[data-mobile-menu-open] .mobile-menu-toggle span:nth-child(1) {
        transform: translateY(5.5px) rotate(45deg);
    }

    .site-header[data-mobile-menu-open] .mobile-menu-toggle span:nth-child(2) {
        opacity: 0;
    }

    .site-header[data-mobile-menu-open] .mobile-menu-toggle span:nth-child(3) {
        transform: translateY(-5.5px) rotate(-45deg);
    }

    .mobile-sidebar-backdrop {
        position: fixed;
        inset: 0;
        z-index: 60;
        background: rgba(0, 0, 0, 0.52);
        opacity: 0;
        pointer-events: none;
        transition: opacity var(--transition-base);
    }

    .mobile-sidebar {
        position: fixed;
        top: 0;
        right: 0;
        bottom: 0;
        z-index: 70;
        display: flex;
        width: min(84vw, 320px);
        flex-direction: column;
        padding: 18px;
        background: var(--color-canvas);
        border-left: 1px solid var(--color-hairline);
        box-shadow: var(--shadow-lg);
        transform: translateX(100%);
        transition: transform 240ms ease;
    }

    .site-header[data-mobile-menu-open] .mobile-sidebar-backdrop {
        opacity: 1;
        pointer-events: auto;
    }

    .site-header[data-mobile-menu-open] .mobile-sidebar {
        transform: translateX(0);
    }

    .mobile-sidebar-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--color-hairline-soft);
    }

    .mobile-sidebar-close {
        display: inline-flex;
        width: 34px;
        height: 34px;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--color-hairline);
        border-radius: var(--radius-sm);
        background: rgba(255, 255, 255, 0.025);
        color: var(--color-body);
        transition:
            color var(--transition-fast),
            border-color var(--transition-fast),
            background-color var(--transition-fast);
    }

    .mobile-sidebar-close:hover {
        color: var(--color-ink);
        border-color: var(--color-rim, var(--fb-rim));
        background: rgba(255, 255, 255, 0.055);
    }

    .mobile-sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding-block: 18px;
        text-align: left;
    }

    .mobile-sidebar-nav a {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        min-height: 42px;
        border-radius: var(--radius-sm);
        padding: 9px 12px;
        color: var(--color-body-strong);
        font-size: 0.9375rem;
        font-weight: 500;
        transition:
            color var(--transition-fast),
            background-color var(--transition-fast);
    }

    .mobile-sidebar-nav a:hover {
        color: var(--color-ink);
        background: rgba(255, 255, 255, 0.045);
    }

    .mobile-sidebar-actions {
        display: flex;
        flex-direction: column;
        gap: 16px;
        margin-top: auto;
        padding-top: 18px;
        border-top: 1px solid var(--color-hairline-soft);
    }

    .mobile-sidebar-cta {
        width: 100%;
    }

    .mobile-sidebar-socials {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
    }

    .mobile-sidebar-socials a {
        display: inline-flex;
        min-height: 36px;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--color-hairline);
        border-radius: var(--radius-sm);
        color: var(--color-body);
        font-size: 0.8125rem;
        font-weight: 500;
        transition:
            color var(--transition-fast),
            border-color var(--transition-fast),
            background-color var(--transition-fast);
    }

    .mobile-sidebar-socials a:hover {
        color: var(--color-ink);
        border-color: var(--color-rim, var(--fb-rim));
        background: rgba(255, 255, 255, 0.045);
    }

    @media (min-width: 920px) {
        .mobile-menu-toggle,
        .mobile-sidebar-backdrop,
        .mobile-sidebar {
            display: none;
        }
    }

    @media (max-width: 640px) {
        .nav-cta {
            display: none;
        }
    }

    @media (max-width: 420px) {
        .wordmark {
            display: none;
        }
    }
</style>
